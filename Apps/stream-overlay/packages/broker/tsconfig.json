{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Broker is a Node.js process. NodeNext gives correct ESM resolution for Node.
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"]
}
