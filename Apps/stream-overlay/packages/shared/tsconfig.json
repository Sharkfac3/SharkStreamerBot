{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Shared types are consumed by both Vite (overlay) and Node (broker).
    // Using bundler resolution here; broker will override if needed.
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"]
}
